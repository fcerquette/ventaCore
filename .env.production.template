# ─────────────────────────────────────────────
#  VentaCore — Variables de entorno (PRODUCCIÓN)
#  Copiar a .env.production y completar TODOS los campos.
#    cp .env.production.template .env.production
#  .env.production está en .gitignore: NUNCA lo subas al repo.
# ─────────────────────────────────────────────

NODE_ENV=production

# ── API (NestJS) ──
API_PORT=3000
API_PREFIX=api

# ── Postgres (TypeORM) ──
# DB_PASSWORD lo genera setup-server.sh y lo imprime al final. Copiarlo de ahí.
DB_HOST=localhost
DB_PORT=5432
DB_USER=ventacore
DB_PASSWORD=
DB_NAME=ventacore
# synchronize=true deja que TypeORM altere el esquema solo en cada arranque.
# Sirve para el primer deploy, con la base vacía. Una vez que haya datos
# reales, poner false y usar migraciones: un cambio de entidad puede
# borrar columnas sin aviso.
DB_SYNCHRONIZE=true

# ── Firebase Admin (API) ──
# Ruta al archivo service-account.json descargado de Firebase Console.
# Ese archivo es un secreto: copiarlo al server por scp, nunca commitearlo.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=/home/ubuntu/ventacore/firebase-service-account.json

# ── Frontend (Vite) ──
# En producción Nginx hace proxy, asi que la URL es relativa.
VITE_API_URL=/api
VITE_BASE_PATH=/

# ── Firebase Web SDK (Frontend) ──
# Obtener de Firebase Console > Project Settings > General > Your apps
# Estas VITE_* viajan al bundle del navegador por diseño: no son secretos.
# Firebase se protege con Security Rules, no ocultando estas claves.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
